#!/usr/bin/env python3
"""
aegis.VerifyPackages — RPC service handler running in sys-copilot.
Inspects package names to verify there are no security contraindications in the knowledge base.
"""

import sys
import json
import subprocess

def query_kb(package_name: str) -> str:
    """Queries the sys-knowledge RAG database for a package's safety status."""
    try:
        process = subprocess.Popen(
            ["qrexec-client-vm", "sys-knowledge", "aegis.KnowledgeQuery"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE
        )
        # Search query looking for advisories or warnings on the package
        query = f"security advisory vulnerability compromise {package_name}"
        stdout, stderr = process.communicate(input=query.encode('utf-8'), timeout=10)
        if process.returncode == 0:
            return stdout.decode('utf-8', errors='replace').strip()
    except Exception:
        pass
    return ""

def main():
    # Read package transaction list from stdin
    # Format is expected to be JSON list of strings, e.g. ["pkg1-ver1", "pkg2-ver2"]
    try:
        raw = sys.stdin.read().strip()
        if not raw:
            sys.exit(0)
        packages = json.loads(raw)
    except Exception:
        sys.stderr.write("Error: Invalid package list input.\n")
        sys.exit(1)

    warnings = []
    
    # Check each package in the transaction
    for pkg in packages:
        # Extract base package name robustly
        parts = pkg.split('-')
        name_parts = []
        for part in parts:
            if part and part[0].isdigit():
                break
            name_parts.append(part)
        pkg_name = "-".join(name_parts)
        if not pkg_name:
            pkg_name = pkg
            
        pkg_name = pkg_name.strip()
        if not pkg_name:
            continue
            
        kb_context = query_kb(pkg_name)
        lower_context = kb_context.lower()
        
        import re
        # Regex search inside retrieved context to avoid false positives
        if re.search(r'\b(compromise|malicious|backdoor|contraindicated|critical vulnerability)\b', lower_context):
            warnings.append({
                "package": pkg,
                "reason": f"Database flag found: {kb_context[:200]}..."
            })
            
    # Output JSON warnings to stdout
    sys.stdout.write(json.dumps(warnings) + "\n")
    sys.stdout.flush()

if __name__ == "__main__":
    main()
