#!/usr/bin/env python3
"""
aegis.LLMProxyGuest — qrexec RPC handler running inside sys-copilot.
Proxy inference requests from guest VMs to the local llama-server socket.
Performs input sanitization, length validation, and redaction.
"""

import sys
import json
import socket
import re
import os

LLM_SOCK = os.getenv("AEGIS_LLM_SOCK", "/run/aegis/llm.sock")
MAX_INPUT_BYTES = 65536  # Max 64KB prompt request

# Censor patterns to protect system boundaries
CENSOR_PATTERNS = [
    re.compile(r"ignore\s+(all\s+|the\s+)?(previous\s+)?(instructions|directives|rules|system\s+prompt)", re.I),
    re.compile(r"do\s+not\s+follow\s+(any\s+)?(previous\s+)?(instructions|directives|rules)", re.I),
]

def sanitize_text(text: str) -> str:
    if not text:
        return ""
    for pat in CENSOR_PATTERNS:
        text = pat.sub("[REDACTED]", text)
    return text

def sanitize_messages(messages):
    if not isinstance(messages, list):
        return []
    clean = []
    for msg in messages:
        if isinstance(msg, dict) and "content" in msg:
            msg["content"] = sanitize_text(msg["content"])
            clean.append(msg)
    return clean

def main():
    # 1. Read input with size cap
    raw_bytes = sys.stdin.buffer.read(MAX_INPUT_BYTES + 1)
    if len(raw_bytes) > MAX_INPUT_BYTES:
        sys.stderr.write("Error: Request too large.\n")
        sys.exit(1)
        
    raw = raw_bytes.decode("utf-8", errors="replace").strip()
    if not raw:
        sys.exit(0)
        
    # 2. Parse request JSON or HTTP payload
    is_http = False
    body = raw
    headers = ""
    
    if raw.startswith("POST ") or raw.startswith("GET "):
        is_http = True
        parts = raw.split("\r\n\r\n", 1)
        headers = parts[0]
        body = parts[1] if len(parts) > 1 else ""

    try:
        req = json.loads(body)
        if "messages" in req:
            req["messages"] = sanitize_messages(req["messages"])
        body = json.dumps(req)
    except Exception:
        sys.stderr.write("Error: Invalid JSON payload.\n")
        sys.exit(1)

    # 3. Connect to the local llama-server socket and forward the request
    if not os.path.exists(LLM_SOCK):
        sys.stderr.write("Error: Local inference socket not available.\n")
        sys.exit(1)
        
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        s.connect(LLM_SOCK)
        
        if not is_http:
            http_req = (
                f"POST /v1/chat/completions HTTP/1.1\r\n"
                f"Host: localhost\r\n"
                f"Content-Type: application/json\r\n"
                f"Content-Length: {len(body)}\r\n"
                f"\r\n"
                f"{body}"
            )
            s.sendall(http_req.encode('utf-8'))
        else:
            new_headers = []
            for line in headers.split("\r\n"):
                if not line.lower().startswith("content-length:"):
                    new_headers.append(line)
            new_headers.append(f"Content-Length: {len(body)}")
            reconstructed = "\r\n".join(new_headers) + "\r\n\r\n" + body
            s.sendall(reconstructed.encode('utf-8'))
            
        s.settimeout(60)
        while True:
            chunk = s.recv(4096)
            if not chunk:
                break
            sys.stdout.buffer.write(chunk)
            sys.stdout.flush()
    except Exception as e:
        sys.stderr.write(f"Error connecting to LLM: {str(e)}\n")
        sys.exit(1)
    finally:
        s.close()

if __name__ == "__main__":
    main()
