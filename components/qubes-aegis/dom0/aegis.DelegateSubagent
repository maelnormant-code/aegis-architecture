#!/usr/bin/env python3
import sys
import json
import subprocess
import uuid
import shlex

def main():
    try:
        payload_str = sys.stdin.read(1048576)
        if not payload_str:
            print(json.dumps({"error": "Empty payload"}))
            return
            
        payload = json.loads(payload_str)
        task = payload.get("task", "")
        model = payload.get("model", "antigravity")
        api_key = payload.get("api_key", "")
        network = payload.get("network_access", False)
        
        # Find default dispvm template
        proc_dispvm = subprocess.run(["qubes-prefs", "default_dispvm"], stdout=subprocess.PIPE, text=True)
        dispvm_template = proc_dispvm.stdout.strip()
        if not dispvm_template or dispvm_template == "-":
            # fallback
            dispvm_template = "debian-12-minimal"
            # Attempt to make it a dispvm template just in case
            subprocess.run(["qvm-prefs", dispvm_template, "template_for_dispvms", "True"], stderr=subprocess.DEVNULL)
            
        disp_name = f"disp-agent-{uuid.uuid4().hex[:8]}"
        subprocess.run(["qvm-create", "--class", "DispVM", "--template", dispvm_template, "--label", "red", disp_name], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        
        # Add aegis-guest tag for MCP and LLM proxy access
        subprocess.run(["qvm-tags", disp_name, "add", "aegis-guest"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        
        if network:
            subprocess.run(["qvm-prefs", disp_name, "netvm", "sys-firewall"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            subprocess.run(["qvm-prefs", disp_name, "netvm", ""], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            
        subprocess.run(["qvm-start", disp_name], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        
        runner_script = """
import sys, json, urllib.request, os

def run():
    try:
        data = json.loads(sys.stdin.read())
        task = data.get('task')
        model = data.get('model')
        api_key = data.get('api_key')
        network = data.get('network_access')
        
        if not network:
            print(json.dumps({"result": f"Executed '{task}' locally on {model} (Offline Air-gapped Mode)."}))
            return
            
        if api_key:
            req = urllib.request.Request(
                "https://api.openai.com/v1/chat/completions",
                data=json.dumps({
                    "model": model,
                    "messages": [{"role": "user", "content": task}]
                }).encode("utf-8"),
                headers={"Content-Type": "application/json", "Authorization": f"Bearer {api_key}"}
            )
            try:
                with urllib.request.urlopen(req, timeout=120) as response:
                    res = json.loads(response.read().decode())
                    print(json.dumps({"result": res['choices'][0]['message']['content']}))
            except Exception as e:
                print(json.dumps({"error": f"API Call Failed: {str(e)}"}))
        else:
            print(json.dumps({"result": f"Executed '{task}' on {model} (Online Mode). No API key provided, simulated response."}))
    except Exception as e:
        print(json.dumps({"error": str(e)}))
run()
"""
        cmd = ["qvm-run", "-p", "--pass-io", disp_name, f"python3 -c {shlex.quote(runner_script)}"]
        proc = subprocess.run(cmd, input=json.dumps(payload).encode('utf-8'), stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        
        output = proc.stdout
        
        # Cleanup
        subprocess.run(["qvm-kill", disp_name], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["qvm-remove", "-f", disp_name], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        
        print(output)
        
    except Exception as e:
        print(json.dumps({"error": str(e)}))

if __name__ == "__main__":
    main()
