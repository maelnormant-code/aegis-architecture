#!/usr/bin/env python3
"""aegis.RequestDocBuild — qrexec RPC handler (runs in Dom0).

Receives a documentation topic request from sys-copilot, validates it
against a hardcoded topic whitelist, then triggers sys-knowledge-builder
to fetch the documentation, rebuild the knowledge index, and auto-deploy
it to sys-knowledge via the existing verified pipeline.

Security model:
  - Runs in Dom0 with minimal privileges.
  - Input is strictly validated (JSON schema, topic whitelist).
  - All subprocess calls use explicit argument lists (no shell=True).
  - Maximum one build job can run at a time (lockfile).
  - Rate-limited: one rebuild per 3600 seconds.
  - The build itself runs in the isolated sys-knowledge-builder VM.
  - Deployment reuses the SHA256-verified verify-and-deploy pipeline.

Usage (called by qrexec daemon, stdin = JSON):
  {"topic": "apparmor", "description": "Need AppArmor profile writing guide"}

Output (JSON on stdout):
  {"status": "ok", "message": "..."} or {"status": "error", "message": "..."}
"""

import fcntl
import json
import os
import subprocess
import sys
import time

# ── Configuration ───────────────────────────────────────────────────────────
MAX_INPUT         = 8192
LOG_FILE          = "/var/log/aegis-doc-build.log"
LOCK_FILE         = "/run/aegis-doc-build.lock"
RATE_LIMIT_FILE   = "/run/aegis-doc-build.ratelimit"
RATE_LIMIT_SECS   = 3600          # max one full rebuild per hour
BUILD_VM          = "sys-knowledge-builder"
BUILD_SCRIPT      = "/home/user/qubes-builder/components/qubes-aegis/sys-knowledge-builder/build-knowledge-index.sh"
DEPLOY_SCRIPT     = "/etc/qubes-aegis/verify-and-deploy-knowledge.sh"
TARBALL_PATH      = "/home/user/knowledge-index-output/knowledge-index.tar.gz"
SHA256_PATH       = "/home/user/knowledge-index-output/knowledge-index.sha256"
PINS_FILE         = "/etc/qubes-aegis/knowledge-pins.json"
TARGET_VM         = "sys-knowledge"
TARGET_DIR        = "/var/lib/aegis"

